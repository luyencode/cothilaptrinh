---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const docs = (await getCollection('docs')).sort((a, b) => {
    if (a.data.sectionOrder !== b.data.sectionOrder) return a.data.sectionOrder - b.data.sectionOrder;
    return a.data.order - b.data.order;
  });
  return docs.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: docs[i - 1] ? { title: docs[i - 1].data.title, id: docs[i - 1].id } : null,
      next: docs[i + 1] ? { title: docs[i + 1].data.title, id: docs[i + 1].id } : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---
<DocsLayout title={entry.data.title} description={entry.data.description} prev={prev} next={next}>
  <Content />
</DocsLayout>
