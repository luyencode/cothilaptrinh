---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<BaseLayout
  title="Blog | Cô Thi Lập Trình"
  description="Bài viết về học lập trình, luyện thi và kinh nghiệm giảng dạy từ Cô Thi."
  accent="#1E3A63"
  heroClass="lighthero"
>
  <section class="hero tint"><div class="wrap">
    <span class="eyebrow"><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 19.5A2.5 2.5 0 0 0 6.5 22H20V2H6.5A2.5 2.5 0 0 0 4 4.5v15z"/></svg> Blog</span>
    <h1>Bài viết từ Cô Thi</h1>
    <p class="lead">Chia sẻ về học lập trình, luyện thi và kinh nghiệm giảng dạy - cập nhật thường xuyên.</p>
  </div></section>

  <section class="section"><div class="wrap">
    {posts.length === 0 ? (
      <p class="muted">Chưa có bài viết nào. Quay lại sau nhé!</p>
    ) : (
      <div class="grid g3 cards">
        {posts.map((post) => (
          <a class="card" href={`/blog/${post.id}`}>
            {post.data.tags[0] && <span class="tag">{post.data.tags[0]}</span>}
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="more">Đọc bài viết <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
          </a>
        ))}
      </div>
    )}
  </div></section>
</BaseLayout>
