---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';

const CONTACT_ENDPOINT =
  import.meta.env.PUBLIC_CONTACT_ENDPOINT ??
  'https://script.google.com/macros/s/AKfycbzdz9uDQ8OPPUaKCQBYhtyKWOkkzegQMgKSeWDKjkPVRnNWmbXu09UUNMtH2uvzoWGsdA/exec';
---
<BaseLayout
  title="Liên hệ | Cô Thi Lập Trình"
  description="Học online toàn quốc - bạn ở đâu cũng có thể tham gia. Cách nhanh nhất là nhắn Zalo để được tư vấn trực tiếp."
  accent="#1f8b3f"
  heroClass="lighthero"
>
  <section class="hero tint"><div class="wrap">
    <span class="eyebrow"><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> Liên hệ</span>
    <h1>Kết nối với Cô Thi</h1>
    <p class="lead">Học online toàn quốc - bạn ở đâu cũng có thể tham gia. Cách nhanh nhất là nhắn Zalo để được tư vấn trực tiếp.</p>
  </div></section>

  <section class="section"><div class="wrap">
    <div class="grid g3 contact-cards">
      <a class="ccard gold" href="https://zalo.me/0985188655" target="_blank" rel="noopener">
        <span class="ico"><svg width="30px" height="30px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span><h3>Zalo</h3><p>0985 188 655</p><span class="more">Nhắn tin ngay <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span></a>
      <a class="ccard teal" href="tel:0985188655">
        <span class="ico"><svg width="30px" height="30px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.6a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6 6l1.2-1.1a2 2 0 0 1 2.1-.5c.8.3 1.7.5 2.6.6a2 2 0 0 1 1.7 2z"/></svg></span><h3>Điện thoại</h3><p>0985 188 655</p><span class="more">Gọi ngay <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span></a>
      <a class="ccard navy" href="https://cothilaptrinh.vn" target="_blank" rel="noopener">
        <span class="ico"><svg width="30px" height="30px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18"/></svg></span><h3>Website</h3><p>cothilaptrinh.vn</p><span class="more">Ghé thăm <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span></a>
    </div>

    <div class="contact-2">
      <ContactForm endpoint={CONTACT_ENDPOINT} />
      <aside class="cinfo">
        <h3>Thông tin</h3>
        <p><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18"/></svg> <span><b>Hình thức:</b> Học online toàn quốc, không có địa chỉ lớp cố định.</span></p>
        <p><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="14" height="12" rx="2"/><path d="m22 8-6 4 6 4z"/></svg> <span><b>Cách học:</b> Video tự học, lớp trực tiếp và kèm 1 kèm 1.</span></p>
        <p><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg> <span><b>Phương châm:</b> Dạy học với trọn vẹn yêu thương.</span></p>
        <div class="cta-row"><a class="btn btn-gold" href="https://zalo.me/0985188655" target="_blank" rel="noopener"><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> Tư vấn qua Zalo</a></div>
      </aside>
    </div>
  </div></section>
</BaseLayout>
