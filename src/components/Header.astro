---
import { nav, isActive, isGroup, isGroupActive } from '../data/nav';

interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;
---
<header class="site-head">
  <div class="wrap head-in">
    <a class="brand" href="/">
      <span class="mark"><i class="a"></i><i class="b"></i><i class="c"></i><i class="d"></i></span>
      <b>Cô Thi <i>Lập Trình</i></b>
    </a>
    <button class="burger" aria-label="Menu" onclick="document.body.classList.toggle('nav-open')">
      <span></span><span></span><span></span></button>
    <nav class="main-nav">
      {nav.map((item) =>
        isGroup(item) ? (
          <div class={`nav-drop ${isGroupActive(item, currentPath) ? 'on' : ''}`}>
            <button type="button" class="nav-drop-btn" aria-haspopup="true" aria-expanded="false" onclick="this.closest('.nav-drop').classList.toggle('open')">
              {item.label}
              <svg class="nav-drop-caret" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="nav-drop-menu">
              {item.children.map((child) => (
                <a href={child.href} class={isActive(child.href, currentPath) ? 'on' : ''}>{child.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href} class={isActive(item.href, currentPath) ? 'on' : ''}>{item.label}</a>
        )
      )}
      <a class="btn btn-gold btn-sm nav-cta" href="https://zalo.me/0985188655" target="_blank" rel="noopener"><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> Tư vấn Zalo</a>
    </nav>
  </div>
</header>

<script>
  // Close any open dropdown when clicking outside it, and when navigating away.
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    document.querySelectorAll('.nav-drop.open').forEach((drop) => {
      if (!drop.contains(target)) drop.classList.remove('open');
    });
  });
</script>

<style>
  .head-in { width: min(1160px, 94vw); }

  .nav-drop { position: relative; }
  .nav-drop-btn {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 9px 12px; border-radius: 9px; font-weight: 600; font-size: .96rem;
    color: #33425c; background: none; border: 0; cursor: pointer; font-family: inherit;
  }
  .nav-drop-btn:hover { background: #f1f3f8; color: var(--navy); }
  .nav-drop.on .nav-drop-btn { color: var(--navy); background: color-mix(in srgb, var(--navy) 9%, #fff); }
  .nav-drop-caret { transition: transform .15s ease; }
  .nav-drop.open .nav-drop-caret { transform: rotate(180deg); }

  .nav-drop-menu {
    display: none; position: absolute; top: calc(100% + 6px); left: 0; min-width: 180px;
    background: #fff; border-radius: 12px; box-shadow: 0 18px 34px rgba(16,30,55,.16);
    padding: 6px; flex-direction: column; z-index: 60;
  }
  .nav-drop-menu a { padding: 9px 12px; border-radius: 8px; font-weight: 600; font-size: .95rem; color: #33425c; white-space: nowrap; }
  .nav-drop-menu a:hover { background: #f1f3f8; color: var(--navy); }
  .nav-drop-menu a.on { color: var(--navy); background: color-mix(in srgb, var(--navy) 9%, #fff); }

  @media (min-width: 921px) {
    .nav-drop:hover .nav-drop-menu, .nav-drop.open .nav-drop-menu { display: flex; }
  }
  @media (max-width: 920px) {
    .nav-drop-btn { width: 100%; justify-content: space-between; padding: 13px 8px; border-bottom: 1px solid #f0f2f6; }
    .nav-drop-menu { display: none; position: static; box-shadow: none; padding: 0 0 0 14px; }
    .nav-drop.open .nav-drop-menu { display: flex; }
  }
</style>
