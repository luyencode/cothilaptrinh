---
import { nav, isActive } from '../data/nav';

interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;
---
<header class="site-head">
  <div class="wrap head-in">
    <a class="brand" href="/">
      <span class="mark"><i class="a"></i><i class="b"></i><i class="c"></i><i class="d"></i></span>
      <b>Cô Thi <i>Lập Trình</i></b>
    </a>
    <button class="burger" aria-label="Menu" onclick="document.body.classList.toggle('nav-open')">
      <span></span><span></span><span></span></button>
    <nav class="main-nav">
      {nav.map((item) => (
        <a href={item.href} class={isActive(item.href, currentPath) ? 'on' : ''}>{item.label}</a>
      ))}
      <a class="btn btn-gold btn-sm nav-cta" href="https://zalo.me/0985188655" target="_blank" rel="noopener"><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> Tư vấn Zalo</a>
    </nav>
  </div>
</header>

<style>
  /* The original design's 7-item nav fit the shared .wrap (1160px) exactly.
     Adding Blog/Tài liệu pushed it to 9 items, so the header alone gets a
     little more room and slightly tighter link spacing - global styles.css
     and every other page's .wrap width stay untouched. */
  .head-in { width: min(1300px, 94vw); }
  .main-nav a { padding: 9px 9px; font-size: .92rem; }
  .main-nav { gap: 2px; }
</style>
