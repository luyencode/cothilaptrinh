---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  accent?: string;
  cover?: string;
}
const { title, description, date, tags, accent = '#1E3A63', cover } = Astro.props;
const formattedDate = date.toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' });
---
<BaseLayout
  title={`${title} | Cô Thi Lập Trình`}
  description={description}
  accent={accent}
  heroClass="lighthero"
  ogImage={cover}
  ogType="article"
  publishedTime={date}
>
  <section class="hero tint"><div class="wrap narrow">
    <span class="eyebrow"><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 19.5A2.5 2.5 0 0 0 6.5 22H20V2H6.5A2.5 2.5 0 0 0 4 4.5v15z"/></svg> Blog</span>
    <h1>{title}</h1>
    <p class="lead">{description}</p>
    <div class="post-meta">
      <span>{formattedDate}</span>
      {tags.length > 0 && (
        <span class="post-tags">
          {tags.map((t) => <span class="post-tag">{t}</span>)}
        </span>
      )}
    </div>
  </div></section>

  <section class="section"><div class="wrap narrow post-content">
    <slot />
  </div></section>

  <section class="section soft"><div class="wrap narrow center">
    <a class="btn btn-navy" href="/blog"><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg> Xem tất cả bài viết</a>
  </div></section>
</BaseLayout>

<style>
  .post-meta { display: flex; gap: 14px; align-items: center; margin-top: 18px; flex-wrap: wrap; color: var(--muted); font-size: .9rem; }
  .post-tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .post-tag { background: color-mix(in srgb, var(--c) 12%, #fff); color: var(--navy); padding: 4px 12px; border-radius: 999px; font-weight: 600; font-size: .78rem; }
  .post-content :global(h2) { margin-top: 2em; margin-bottom: .6em; font-size: 1.5rem; }
  .post-content :global(h3) { margin-top: 1.6em; margin-bottom: .5em; font-size: 1.2rem; }
  .post-content :global(p) { margin-bottom: 1.1em; line-height: 1.75; }
  .post-content :global(ul), .post-content :global(ol) { margin: 0 0 1.1em 1.3em; line-height: 1.7; }
  .post-content :global(li) { margin-bottom: .4em; }
  .post-content :global(a) { color: var(--navy); text-decoration: underline; }
  .post-content :global(blockquote) { border-left: 3px solid var(--gold); padding-left: 16px; color: var(--muted); font-style: italic; margin: 1.2em 0; }
  .post-content :global(code) { background: #f1f3f8; padding: .15em .4em; border-radius: 6px; font-size: .9em; }
  .post-content :global(pre) { background: var(--navy-d); color: #e7eefb; padding: 16px 18px; border-radius: 14px; overflow-x: auto; margin: 1.2em 0; }
  .post-content :global(pre code) { background: none; padding: 0; color: inherit; }
  .post-content :global(img) { border-radius: var(--r); margin: 1.2em 0; }
</style>
